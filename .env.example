# Edge AI Railway Safety System Dashboard Configuration

# Application title displayed in the header
VITE_APP_TITLE=Edge AI Railway Safety System

# Relative or absolute URL of the telemetry status JSON file
VITE_STATUS_API_URL=./status.json

# Interval in milliseconds for polling the status endpoint
VITE_POLL_INTERVAL_MS=1000

# Default IP Camera stream URL (leave empty to use the SVG Canvas Simulator)
# Example: http://192.168.1.100:8080/video
VITE_DEFAULT_CAMERA_URL=

# Host URL of the edge system shown in telemetry statistics
VITE_SYSTEM_HOST=http://localhost:5173
